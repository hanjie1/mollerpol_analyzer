# target to generate assembly for a file
gem/MPDModule.cxx.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/MollerPol.dir/build.make CMakeFiles/MollerPol.dir/gem/MPDModule.cxx.s
.PHONY : gem/MPDModule.cxx.s

